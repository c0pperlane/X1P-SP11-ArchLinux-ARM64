CONFIG_ARCH_SC7180=y
CONFIG_ARCH_SC7280=y
CONFIG_ARCH_SC8280XP=y
CONFIG_ARCH_SDM845=y
CONFIG_ARCH_SM8150=y
CONFIG_ARCH_SM8250=y
CONFIG_ARCH_SM8350=y
