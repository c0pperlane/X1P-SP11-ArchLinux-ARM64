# Interconnect (NoC bandwidth management - required for display, camera, UFS)
CONFIG_INTERCONNECT_QCOM=y
CONFIG_INTERCONNECT_QCOM_X1E80100=y

# Clock drivers (X1E80100-specific clocks)
# GCC must be built-in; display/camera/GPU clocks can be modules
CONFIG_CLK_X1E80100_GCC=y
CONFIG_CLK_X1E80100_TCSRCC=y
CONFIG_CLK_X1E80100_DISPCC=m
CONFIG_CLK_X1E80100_CAMCC=m
CONFIG_CLK_X1E80100_GPUCC=m

# Pin control (mandatory for all GPIO/peripheral routing on X1E80100)
CONFIG_PINCTRL_X1E80100=y

# CPUFreq / Thermal
CONFIG_ARM_QCOM_CPUFREQ_HW=y
CONFIG_ARM_QCOM_CPUFREQ_NVMEM=y
CONFIG_QCOM_TSENS=y
CONFIG_QCOM_SPMI_TEMP_ALARM=y
CONFIG_THERMAL_GOV_POWER_ALLOCATOR=y
CONFIG_DEVFREQ_THERMAL=y

# PCIe / NVMe
CONFIG_PCI=y
CONFIG_PCI_MSI=y
CONFIG_PCI_QUIRKS=y
CONFIG_PCIEPORTBUS=y
CONFIG_HOTPLUG_PCI=y
CONFIG_PCIEAER=y
CONFIG_PCIE_DPC=y
CONFIG_PCIE_PME=y
CONFIG_PCIE_DW=y
CONFIG_PCIE_DW_HOST=y
CONFIG_PCIE_QCOM=y
# CONFIG_PCIE_QCOM_EP is not set
# (EP = Endpoint mode; Surface Pro 11 is a host, not a PCIe endpoint device)
CONFIG_NVME_FABRICS=y
CONFIG_NVME_RDMA=y
CONFIG_NVME_TCP=y
CONFIG_NVME_TARGET=y
CONFIG_NVME_TARGET_LOOP=y
CONFIG_NVME_TARGET_RDMA=y
CONFIG_NVME_TARGET_TCP=y

# USB / Type-C
CONFIG_USB=y
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_XHCI_PCI=y
CONFIG_USB_EHCI_HCD=y
CONFIG_USB_OHCI_HCD=y
CONFIG_USB_STORAGE=y
CONFIG_USB_UAS=y
CONFIG_TYPEC=y
CONFIG_TYPEC_TCPM=y
CONFIG_TYPEC_TCPCI=y
CONFIG_TYPEC_QCOM_PMIC=y
CONFIG_USB_DWC3=y
CONFIG_USB_DWC3_PCI=y
CONFIG_USB_DWC3_QCOM=y
CONFIG_USB_ROLE_SWITCH=y
CONFIG_USB_CONN_GPIO=y

# SDHCI / eMMC / SD
CONFIG_MMC=y
CONFIG_MMC_BLOCK=y
CONFIG_SDIO_UART=y
CONFIG_MMC_SDHCI=y
CONFIG_MMC_SDHCI_PLTFM=y
CONFIG_MMC_SDHCI_OF_ARASAN=y
CONFIG_MMC_SDHCI_PCI=y
CONFIG_MMC_SDHCI_MSM=y

# Graphics / DRM
# -----------------------------------------------------------------------
# BOOT DISPLAY STRATEGY:
#   1. UEFI/ABL sets up a linear framebuffer.
#   2. SYSFB_SIMPLEFB + DRM_SIMPLEDRM claim it at kernel start (built-in).
#      This gives a working display immediately after handoff, with no
#      firmware/driver init required.
#   3. Once initramfs loads the MSM DRM module, it performs full Adreno
#      and MDP/DPU init and takes over the display pipeline.
#   DRM_MSM=m (module) is REQUIRED so simpledrm can own the fb at boot.
#   Setting DRM_MSM=y (built-in) causes both drivers to race for the
#   framebuffer and can result in a blank/corrupted screen at early boot.
# -----------------------------------------------------------------------
CONFIG_DRM=y
CONFIG_SYSFB=y
CONFIG_SYSFB_SIMPLEFB=y
CONFIG_DRM_SIMPLEDRM=y
CONFIG_DRM_FBDEV_EMULATION=y
CONFIG_FB=y
CONFIG_FB_SIMPLE=y
# MSM DRM as module - loads after initramfs, takes over from simpledrm
CONFIG_DRM_MSM=m
CONFIG_DRM_MSM_DP=y
CONFIG_DRM_MSM_DSI=y
# NOTE: Surface Pro 11 (X1E80100) has no HDMI output, only DP-over-USB-C.
# CONFIG_DRM_MSM_HDMI is intentionally omitted to avoid loading dead code.
CONFIG_DRM_MSM_GPU_STATE=y
CONFIG_QCOM_ADRENO_DEFAULT_SNAPSHOT=y
CONFIG_DRM_DISPLAY_HELPER=y
CONFIG_DRM_PANEL_EDP=y
CONFIG_DRM_PANEL_SIMPLE=y
CONFIG_PHY_QCOM_EDP=y
CONFIG_SYNC_FILE=y
CONFIG_DRM_PANEL_ORIENTATION_QUIRKS=y
# CONFIG_DRM_VIRTIO_GPU is not set
# (Virtio GPU is a virtualization driver; irrelevant on bare-metal Surface Pro 11)

# Sound / Audio
CONFIG_SOUND=y
CONFIG_SND=y
CONFIG_SND_SOC=y
CONFIG_SND_SOC_QCOM=y
# Machine drivers - only enable X1E80100 for Surface Pro 11
# SC7180/SC7280 are disabled because they force-select MAX98357A
# (a simple amp without speaker excursion/thermal protection)
CONFIG_SND_SOC_APQ8016_SBC=y
CONFIG_SND_SOC_MSM8996=y
# CONFIG_SND_SOC_SC7180 is not set
# CONFIG_SND_SOC_SC7280 is not set
CONFIG_SND_SOC_SM8250=y
CONFIG_SND_SOC_SM8450=y
CONFIG_SND_SOC_SM8550=y
CONFIG_SND_SOC_X1E80100=y
CONFIG_SND_SOC_QCOM_COMMON=y
CONFIG_SND_SOC_QCOM_SDW=y
# WCD/WSA codecs as modules (not built-in) for speaker safety
CONFIG_SND_SOC_WCD938X=m
CONFIG_SND_SOC_WCD938X_SDW=m
CONFIG_SND_SOC_WSA883X=m
CONFIG_SND_SOC_WSA884X=m
CONFIG_SND_SOC_LPASS_CDC_DMA=y
CONFIG_SND_SOC_LPASS_MACROS=y
# DISABLED: MAX98357A is a simple amp without excursion/thermal limiting.
# Surface Pro 11 uses Qualcomm WSA smart amps (WSA883X/WSA884X).
# Loading the wrong amp driver can damage speakers.
# CONFIG_SND_SOC_MAX98357A is not set
# CONFIG_SND_SOC_RT5682 is not set
# CONFIG_SND_SOC_RT5682_SDW is not set

# Remoteproc / DSP
CONFIG_REMOTEPROC=y
CONFIG_QCOM_Q6V5_ADSP=y
CONFIG_QCOM_Q6V5_MSS=y
CONFIG_QCOM_Q6V5_PAS=y
CONFIG_QCOM_Q6V5_WCSS=y
CONFIG_QCOM_WCNSS_PIL=y

# Wireless
CONFIG_CFG80211=y
CONFIG_CFG80211_CERTIFICATION_ONUS=y
CONFIG_MAC80211=y
CONFIG_MAC80211_LEDS=y
CONFIG_WLAN=y
# ATH12K as module: its dependency chain (MHI/QMI) forces =m anyway;
# setting =y here is silently downgraded to =m by olddefconfig.
CONFIG_ATH12K=m
CONFIG_ATH12K_DEBUG=y

